# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=crm_prod
DATABASE_URL=postgres://crm:CHANGE_ME_strong_password@postgres:5432/crm_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
JWT_SECRET=CHANGE_ME_at_least_32_random_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_32_random_chars

# ── URLs (replace with your actual domain) ────────────────────────────────────
FRONTEND_URL=https://YOURDOMAIN.com
API_PUBLIC_URL=https://YOURDOMAIN.com/api
NEXT_PUBLIC_API_URL=https://YOURDOMAIN.com/api

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@YOURDOMAIN.com
SMTP_PASS=CHANGE_ME_smtp_password
SMTP_FROM=noreply@YOURDOMAIN.com

# ── AI ────────────────────────────────────────────────────────────────────────
PLATFORM_AI_PROVIDER=openai
PLATFORM_AI_API_KEY=
PLATFORM_AI_MODEL=gpt-4o-mini

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Twilio (optional) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_BASE_URL=https://YOURDOMAIN.com/api

# ── Meta / WhatsApp Cloud API (optional) ─────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ── Backups S3 (optional) ─────────────────────────────────────────────────────
# Configure in Settings → Platform after deployment

# ── Misc ──────────────────────────────────────────────────────────────────────
WHATSAPP_WEB_ENABLED=true
LOG_LEVEL=warn
