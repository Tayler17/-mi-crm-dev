{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": false,
    "assets": [
      { "include": "modules/templates/data/**/*.json", "watchAssets": true }
    ]
  },
  "watchOptions": {
    "ignored": ["uploads/**", "backups/**", "node_modules/**", "dist/**"]
  }
}
